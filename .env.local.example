# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these values in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public app URL — used in auth redirect links (local + production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional but recommended: send welcome emails via Resend
# Without this, Supabase Auth sends the recovery email (requires SMTP in Supabase)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=WSSO <onboarding@resend.dev>
