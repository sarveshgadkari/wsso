# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these values in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public app URL — used in set-password email links and auth redirects
NEXT_PUBLIC_APP_URL=https://wsso.vercel.app

# Resend — welcome / set-password emails when admin creates an employee
# onboarding@resend.dev = Resend test sender (no custom domain needed)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=onboarding@resend.dev
