# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these values in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public app URL — used in set-password email links and auth redirects
NEXT_PUBLIC_APP_URL=https://wsso.vercel.app

# Brevo SMTP — welcome / set-password emails when admin creates an employee
# Get SMTP key from: Brevo → SMTP & API → SMTP keys (not your Brevo login password)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=b06b82001@smtp-brevo.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-key-here
EMAIL_FROM=TLB Enterprise <support@tlbisbig.world>
